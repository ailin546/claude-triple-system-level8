{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoWrite(*)",
      "NotebookEdit(*)",
      "Agent(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/session-start.js\""
          }
        ],
        "description": "Load previous context and detect package manager"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/task-router.js\""
          }
        ],
        "description": "Initialize task mode router (Fast/Standard/Heavy)"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/careful-guard.js\""
          }
        ],
        "description": "[Always-on] Block destructive commands (rm -rf, DROP TABLE, git push --force)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/freeze-guard.js\""
          }
        ],
        "description": "[Always-on] Block edits outside frozen directory (when /freeze is active)"
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/pre-tool-escalate.js\""
          }
        ],
        "description": "[Always-on] Auto-escalate mode based on tool input risk signals"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/auto-tmux-dev.js\""
          }
        ],
        "description": "[Standard+] Auto-start dev servers in tmux (mode-gated)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/suggest-compact.js\""
          }
        ],
        "description": "[Standard+] Suggest manual compaction at logical intervals (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT:-.}/.claude/skills/ecc-continuous-learning-v2/hooks/observe.sh\" pre"
          }
        ],
        "description": "[Standard+] Continuous learning v2 - capture tool use observations (pre, mode-gated)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/post-edit-light.js\""
          }
        ],
        "description": "[Always-on] Lightweight post-edit: format + console.log warn + risk scan"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT:-.}/.claude/skills/ecc-continuous-learning-v2/hooks/observe.sh\" post"
          }
        ],
        "description": "[Standard+] Continuous learning v2 - capture tool use observations (post, mode-gated)"
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/drift-detector.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "[Standard+] Track agent drift score (mode-gated)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/quality-gate.js\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "[Standard+] Run quality gate checks after file edits (mode-gated)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/fault-hint.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "[Standard+] Hint to run /verify fault (mode-gated)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "[Heavy] TypeScript check after editing .ts/.tsx files (mode-gated)"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/stop-summary.js\""
          }
        ],
        "description": "[Always-on] Lightweight stop: console.log check + minimal memory"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/session-end.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Standard+] Persist session state (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/cost-tracker.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Standard+] Track token and cost metrics (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/evaluate-session.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Heavy] Evaluate session for extractable patterns (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/shared-state-sync.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Heavy] Clean up stale agents and archive workflows (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/sprint-memory.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Heavy] Update sprint mid-term memory (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/shared-memory-sync.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "[Heavy] Sync to cross-tool shared memory (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/memory-consolidate.js\"",
            "async": true,
            "timeout": 15
          }
        ],
        "description": "[Heavy] Consolidate sprint memories into long-term (mode-gated)"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/memory-promote.js\"",
            "async": true,
            "timeout": 15
          }
        ],
        "description": "[Heavy] Auto-promote universal instincts (mode-gated)"
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT:-.}/.claude/scripts/hooks/pre-compact.js\""
          }
        ],
        "description": "[Always-on] Save state before context compaction"
      }
    ]
  }
}
