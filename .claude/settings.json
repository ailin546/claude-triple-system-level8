{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/auto-tmux-dev.js\""
          }
        ],
        "description": "Auto-start dev servers in tmux"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/suggest-compact.js\""
          }
        ],
        "description": "Suggest manual compaction at logical intervals"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/skills/ecc-continuous-learning-v2/hooks/observe.sh\" pre"
          }
        ],
        "description": "Continuous learning v2 - capture tool use observations (pre)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/skills/ecc-continuous-learning-v2/hooks/observe.sh\" post"
          }
        ],
        "description": "Continuous learning v2 - capture tool use observations (post)"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/quality-gate.js\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run quality gate checks after file edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format JS/TS files after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/post-edit-console-warn.js\""
          }
        ],
        "description": "Warn about console.log statements after edits"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/check-console-log.js\""
          }
        ],
        "description": "Check for console.log in modified files"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/session-end.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/evaluate-session.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Evaluate session for extractable patterns"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/cost-tracker.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Track token and cost metrics per session"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/shared-state-sync.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Clean up stale agents and archive completed workflows in shared-state"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/sprint-memory.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Update sprint mid-term memory with decisions and unfinished work"
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/pre-compact.js\""
          }
        ],
        "description": "Save state before context compaction"
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/scripts/hooks/session-start.js\""
          }
        ],
        "description": "Load previous context and detect package manager"
      }
    ]
  }
}
